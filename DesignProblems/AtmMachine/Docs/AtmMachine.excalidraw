      "updated": 1,
      "link": null,
      "locked": false,
      "text": "STAGE 0 — Problem Statement\nDesign an ATM: a customer inserts a card, authenticates with a PIN,\nthen checks balance / withdraws / deposits cash. The machine holds real notes.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "STAGE 0 — Problem Statement\nDesign an ATM: a customer inserts a card, authenticates with a PIN,\nthen checks balance / withdraws / deposits cash. The machine holds real notes.",
      "autoResize": true,
      "lineHeight": 1.25
    },

