      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a4",
      "roundness": null,
      "seed": 1005,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "STAGE 1 — Requirements  (clarify, ~5 min)\n1. Insert & validate card\n2. Enter PIN (max 3 attempts)\n3. Check balance / withdraw / deposit\n4. Another txn, or take card back\n5. Cancel at any point\n6. Per-transaction withdrawal limit\n7. Dispense only if: account has funds AND ATM has the notes\n8. Inventory of notes: 100 / 200 / 500\n\nOUT OF SCOPE (say 2-3, then stop): hardware (reader/keypad/printer),\nreal bank backend / DB, multi-currency & transfers.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "STAGE 1 — Requirements  (clarify, ~5 min)\n1. Insert & validate card\n2. Enter PIN (max 3 attempts)\n3. Check balance / withdraw / deposit\n4. Another txn, or take card back\n5. Cancel at any point\n6. Per-transaction withdrawal limit\n7. Dispense only if: account has funds AND ATM has the notes\n8. Inventory of notes: 100 / 200 / 500\n\nOUT OF SCOPE (say 2-3, then stop): hardware (reader/keypad/printer),\nreal bank backend / DB, multi-currency & transfers.",
      "autoResize": true,
      "lineHeight": 1.25
    },

